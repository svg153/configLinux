#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TARGET_SCRIPT="$REPO_ROOT/SCRIPTS/engram/start-engram-stack.sh"

if [[ ! -f "$TARGET_SCRIPT" ]]; then
  echo "Shared Engram launcher not found: $TARGET_SCRIPT" >&2
  exit 1
fi

exec bash "$TARGET_SCRIPT" --run-e2e-check "$@"